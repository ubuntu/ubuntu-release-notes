#: ../../25.10/index.md:167 6ad760ac80ce4c9a8dbbc6b58d038357
msgid "Support for new Intel® integrated and discrete GPUS"
msgstr ""

#: ../../25.10/index.md:169 d2c1084e095b4ab0b3b2f9e0c00d8849
