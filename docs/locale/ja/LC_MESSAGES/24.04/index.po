#: ../../24.04/index.md:714 ../../24.04/index.md:1056
#: 24b3862fc56543f9bfe5453d04140fd1 57ac632541524b46bf6a2de57bdd8ed2
msgid "RISC-V"
msgstr ""

#: ../../24.04/index.md:715 74618e9865cf40aa8e3ecb1351f1b057
